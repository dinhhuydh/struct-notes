<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Regenerate Article</h1>
  <p class="text-gray-500 mb-8">Create a new version of "<%= @article.title %>" with a different template or tone.</p>

  <%= form_with url: regenerate_article_path(@article), method: :post, class: "space-y-6", data: { controller: "submit-button" } do |f| %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Template</label>
      <select name="template_id" class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500">
        <% @templates.each do |template| %>
          <option value="<%= template.id %>"
                  <%= "selected" if template == @article.template %>>
            <%= template.name %> — <%= template.description %>
          </option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Tone / Voice</label>
      <select name="tone" class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500">
        <% Article::TONES.each do |key, tone| %>
          <option value="<%= key %>" <%= "selected" if key == @article.tone %>>
            <%= tone[:label] %>
          </option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Original Notes</label>
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <pre class="text-sm text-gray-600 whitespace-pre-wrap"><%= @article.raw_notes %></pre>
      </div>
      <p class="text-sm text-gray-500 mt-1">Notes cannot be changed when regenerating. To use different notes, create a new article.</p>
    </div>

    <div class="pt-4 flex space-x-3">
      <button type="submit"
              data-submit-button-target="button"
              data-action="click->submit-button#submit"
              class="flex-1 bg-indigo-600 text-white py-3 px-4 rounded-md font-medium hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed">
        <span data-submit-button-target="label">Regenerate Article</span>
        <span data-submit-button-target="loading" class="hidden flex items-center justify-center">
          <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Generating new version... this may take 15-30 seconds
        </span>
      </button>
      <%= link_to "Cancel", article_path(@article), class: "text-gray-500 hover:text-gray-700 px-4 py-3" %>
    </div>
  <% end %>
</div>
