<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Edit Article</h1>
    <div class="flex space-x-2">
      <%= link_to "View", article_path(@article), class: "text-sm bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-50" %>
      <%= link_to "Back", articles_path, class: "text-sm text-gray-500 hover:text-gray-700 px-4 py-2" %>
    </div>
  </div>

  <%= form_with model: @article, class: "space-y-6" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
      <%= f.text_field :title, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Hook / Intro</label>
      <%= f.text_area :hook, rows: 3, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <% if @article.body_sections.present? %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">Sections</label>
        <div class="space-y-4">
          <% @article.body_sections.each_with_index do |section, i| %>
            <div class="bg-white p-4 rounded-lg border border-gray-200">
              <input type="text" name="article[body_sections_attributes][<%= i %>][heading]"
                     value="<%= section["heading"] %>"
                     class="w-full border border-gray-300 rounded-md px-3 py-2 mb-2 font-semibold focus:ring-indigo-500 focus:border-indigo-500"
                     placeholder="Section heading" />
              <textarea name="article[body_sections_attributes][<%= i %>][content]"
                        rows="4"
                        class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500"
                        placeholder="Section content"><%= section["content"] %></textarea>
              <% if section["source_excerpt"].present? %>
                <div class="mt-2 text-xs text-gray-400 bg-gray-50 p-2 rounded border-l-2 border-gray-300">
                  <span class="font-medium">Source:</span> "<%= section["source_excerpt"] %>"
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Best For</label>
        <%= f.text_area :best_for, rows: 3, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Not For</label>
        <%= f.text_area :not_for, rows: 3, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Ethics & Safety Notes</label>
      <%= f.text_area :ethics_notes, rows: 3, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <% if @article.key_facts.present? %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">Key Facts</label>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @article.key_facts.each_with_index do |fact, i| %>
            <div class="bg-white p-3 rounded-lg border border-gray-200">
              <input type="text" name="article[key_facts_attributes][<%= i %>][label]"
                     value="<%= fact["label"] %>"
                     class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm mb-1 focus:ring-indigo-500 focus:border-indigo-500"
                     placeholder="Label" />
              <input type="text" name="article[key_facts_attributes][<%= i %>][value]"
                     value="<%= fact["value"] %>"
                     class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm focus:ring-indigo-500 focus:border-indigo-500"
                     placeholder="Value" />
              <% if fact["source_excerpt"].present? %>
                <p class="mt-1 text-xs text-gray-400 italic">"<%= fact["source_excerpt"] %>"</p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
      <%= f.select :status, [["Draft", "draft"], ["Published", "published"]], {}, class: "border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="flex space-x-3 pt-4">
      <%= f.submit "Save Article", class: "bg-indigo-600 text-white px-6 py-2 rounded-md font-medium hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Cancel", article_path(@article), class: "text-gray-500 hover:text-gray-700 px-4 py-2" %>
    </div>
  <% end %>

  <% if @article.raw_notes.present? %>
    <details class="mt-8">
      <summary class="text-sm text-gray-500 cursor-pointer hover:text-gray-700 font-medium">View original notes</summary>
      <div class="mt-2 bg-gray-50 p-4 rounded-lg border border-gray-200">
        <pre class="text-sm text-gray-600 whitespace-pre-wrap"><%= @article.raw_notes %></pre>
      </div>
    </details>
  <% end %>
</div>
