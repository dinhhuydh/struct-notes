<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Create New Article</h1>

  <%= form_with url: generate_articles_path, method: :post, multipart: true, class: "space-y-6" do |f| %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Template</label>
      <select name="template_id" class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500">
        <% @templates.each do |template| %>
          <option value="<%= template.id %>"
                  <%= "selected" if template == @default_template %>
                  title="<%= template.description %>">
            <%= template.name %> — <%= template.description %>
          </option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Paste your notes</label>
      <textarea name="raw_notes" rows="12"
                class="w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500"
                placeholder="Paste your rough travel notes here..."><%= params[:raw_notes] %></textarea>
      <p class="text-sm text-gray-500 mt-1">Minimum 50 characters. The more detail, the better the article.</p>
    </div>

    <div class="relative">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-300"></div></div>
      <div class="relative flex justify-center text-sm"><span class="bg-gray-50 px-2 text-gray-500">or</span></div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Upload a .docx file</label>
      <input type="file" name="file" accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
             class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
      <p class="text-sm text-gray-500 mt-1">Max 50 MB. Only .docx files supported.</p>
    </div>

    <div class="pt-4">
      <button type="submit" class="w-full bg-indigo-600 text-white py-3 px-4 rounded-md font-medium hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
        Generate Article
      </button>
      <p class="text-sm text-gray-500 mt-2 text-center">
        You have <%= current_user.generation_limit - current_user.generations_this_month %> generations remaining this month.
      </p>
    </div>
  <% end %>
</div>
