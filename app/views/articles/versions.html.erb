<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Version History</h1>
    <%= link_to "Back", article_path(@article), class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="space-y-4">
    <% @versions.each do |version| %>
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 <%= version == @article ? 'ring-2 ring-indigo-500' : '' %>">
        <div class="flex justify-between items-start">
          <div>
            <div class="flex items-center space-x-2 mb-1">
              <span class="text-sm font-medium text-indigo-600">v<%= version.version_number %></span>
              <% if version == @article %>
                <span class="text-xs bg-indigo-100 text-indigo-700 px-2 py-0.5 rounded-full">Current</span>
              <% end %>
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full"><%= version.tone_label %></span>
              <span class="text-xs <%= version.draft? ? 'text-yellow-600' : 'text-green-600' %>"><%= version.status.capitalize %></span>
            </div>
            <h2 class="text-lg font-semibold text-gray-900"><%= version.title || "Untitled" %></h2>
            <p class="text-sm text-gray-500 mt-1">
              <%= version.template&.name %> &middot; <%= time_ago_in_words(version.created_at) %> ago
            </p>
            <% if version.hook.present? %>
              <p class="text-gray-600 mt-2 text-sm line-clamp-2"><%= version.hook %></p>
            <% end %>
          </div>
          <div class="flex space-x-2 ml-4 shrink-0">
            <%= link_to "View", article_path(version), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
            <%= link_to "Edit", edit_article_path(version), class: "text-sm text-gray-500 hover:text-indigo-600" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
