<div class="max-w-md mx-auto">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">Sign up</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, autofocus: true, class: "mt-1 w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Your name" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autocomplete: "email", class: "mt-1 w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Sign up", class: "w-full bg-indigo-600 text-white py-2 px-4 rounded-md font-medium hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-4 text-center text-sm text-gray-500">
    Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-indigo-600 hover:text-indigo-800" %>
  </div>
</div>
