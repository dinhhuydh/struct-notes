<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "StructNotes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center">
            <%= link_to "StructNotes", root_path, class: "text-xl font-bold text-indigo-600" %>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to "Pricing", pricing_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
            <% if user_signed_in? %>
              <span class="text-sm text-gray-600">
                <%= current_user.generations_remaining %>/<%= current_user.generation_limit %>
              </span>
              <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full <%= current_user.pro? ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600' %>">
                <%= current_user.plan_label %>
              </span>
              <span class="text-sm text-gray-500"><%= current_user.email %></span>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
              <%= link_to "Sign up", new_user_registration_path, class: "text-sm bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <% if notice.present? %>
        <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-md">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-md">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>
